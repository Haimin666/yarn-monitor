# yarn-monitor 配置文件
# 修改后需重启 server.py 生效

# ── YARN ResourceManager ─────────────────────────────────────
YARN_RM_HOST=hadoop-nn-1.bigdata.shiqiao.com
YARN_RM_PORT=8088

# ── DolphinScheduler ─────────────────────────────────────────
DS_BASE_URL=http://olds.bigdata.shiqiao.com
DS_TOKEN=2a323940d94d9a0c47f343d1c91304e2

# 监控的海豚项目（逗号分隔，按需开启/注释）
# 全部项目（total=19，按 instRunningCount 优先）：
DS_PROJECTS=lion_dw_ods,lion_dw_dws,lion_dw_dwd,lion_dw_dim,lion_dw_dm,lion_dw_flow,gps_prod_spark,lion_high,lion_crd_sqqy,lion_crd_sqgr,lion_crd_sqgr3,征信-ETC,征信-小贷,DBA,分析师团队-资金中心,敞口主题任务,老核心数据（生产）,whm-test

# ── 项目 ID 映射（用于生成海豚跳转链接）────────────────────────
# 格式：DS_PROJECT_IDS=项目名:id,项目名:id,...
